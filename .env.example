OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:26b
# Optional: lighter model for sim decisions (wander/talk/coffee), saves compute
OLLAMA_MODEL_LIGHT=gemma4:e4b
# Optional: heavier model for complex tool-use tasks
OLLAMA_MODEL_HEAVY=gemma4:26b
# Max local retries before escalation to premium CLI
LLM_MAX_RETRIES=3
# Ollama context window (default 32K, max 256K for gemma4:26b)
OLLAMA_NUM_CTX=32768
# Extended context for long tasks (Telegram, repo loading)
OLLAMA_NUM_CTX_EXTENDED=131072
WORKSPACE_PATH=./workspace
OBSIDIAN_VAULT_PATH=~/Obsidian
DB_PATH=./data/falkenstein.db
FRONTEND_PORT=8080
# Telegram Bot (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# CLI Bridge
CLI_DAILY_TOKEN_BUDGET=50000
CLI_PROVIDER=claude
